# --- Gemini «Nano Banana» ---
# Ключ из Google AI Studio (https://aistudio.google.com/apikey). Без ключа работает STUB-режим.
GEMINI_API_KEY=
# «Nano Banana» = gemini-2.5-flash-image ; «Nano Banana Pro» = gemini-3-pro-image-preview
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
VARIANTS=3

# --- Резерв: Replicate (FLUX Kontext Pro), ADR-6 ---
# Токен: https://replicate.com/account/api-tokens . Пусто → резерв выключен.
REPLICATE_API_TOKEN=

# --- Печать (CUPS/lpr) ---
# 0 = карточка только сохраняется; 1 = реально печатать. Имя принтера — из `lpstat -p`.
PRINT_ENABLED=0
PRINT_PRINTER=

# --- QR / цифровая версия ---
PUBLIC_BASE_URL=http://localhost:8000
DIGITAL_TTL_HOURS=72
